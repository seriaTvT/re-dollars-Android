<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash background. Light matches the adaptive-icon background (ic_launcher_background);
         the night variant lives in values-night/colors.xml. -->
    <color name="splash_background">#F2CDD9</color>

    <!-- Post-splash Activity window background. Must NOT be white, or a dark-mode cold
         start flashes white between the splash lifting and Compose painting the chat.
         Neutral M3-ish surface tones; the night value lives in values-night/colors.xml. -->
    <color name="window_background">#FFFBFF</color>

    <!-- RD splash-logo fills (R = lighter, D = darker). Light mode = brand pink; the
         night variant (muted rose, for legibility on the warm near-black splash) lives
         in values-night/colors.xml. Only the splash uses these; the launcher icon keeps
         its own pink foreground on the pink adaptive-icon background. -->
    <color name="splash_rd_r">#E3AEAE</color>
    <color name="splash_rd_d">#D99A9A</color>
</resources>
